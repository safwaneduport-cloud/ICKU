// Prisma schema — ICKU
// Step 1 (Foundation): people & access core. More domains are added per build phase.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Local dev: your local Postgres. Production: Supabase Session pooler (IPv4,
  // port 5432) — one connection string that serves both the app and migrations.
  url      = env("DATABASE_URL")
}

model Department {
  id            String         @id
  name          String
  color         String
  users         User[]
  onboardings   Onboarding[]
  knowledgeDocs KnowledgeDoc[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id          String  @id
  name        String
  email       String? @unique
  role        String
  tier        String
  designation String
  status      String  @default("active")
  birthday    String? // "MM-DD"
  joinedOn    String? // "YYYY-MM-DD"
  photoUrl    String? // uploaded profile photo (avatar); null = coloured initials placeholder

  // department (nullable so users can exist before dept assignment)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // reporting hierarchy — the self-referencing FK that *is* the org tree
  reportsToId String?
  reportsTo   User?   @relation("Reports", fields: [reportsToId], references: [id])
  reports     User[]  @relation("Reports")
  // Whether projects/tasks this person creates go live immediately (true,
  // default) or wait for their manager's approval (false). Set by their manager.
  autoApproveProjects Boolean @default(true)
  autoApproveTasks    Boolean @default(true)
  directTasksAssigned   DirectTask[]         @relation("DirectTaskAssigner")
  directTaskAssignments DirectTaskAssignee[] @relation("DirectTaskAssignee")

  // login credentials (created in the seed; used by Step 2 Auth)
  credential AuthCredential?

  // HR — attendance (Step 3)
  attendance      AttendanceRecord[]
  regularizations Regularization[]

  // HR — leave (Step 4)
  leaveRequests LeaveRequest[]

  // HR — payroll (Step 5)
  salary Salary?

  // Services (Step 6)
  expenses        Expense[]
  assetsAssigned  Asset[]  @relation("AssetAssignee")
  ticketsRaised   Ticket[] @relation("TicketRaiser")
  ticketsAssigned Ticket[] @relation("TicketAssignee")
  ticketComments  TicketComment[] @relation("TicketCommentAuthor")

  // Work — events & tasks (Step 7)
  eventsOwned     Event[]        @relation("EventOwner")
  taskAssignments TaskAssignee[]
  eventComments   EventComment[]

  // HR — lifecycle (Step 8)
  exits Exit[]

  // Knowledge (Step 11)
  knowledgeDocs KnowledgeDoc[] @relation("KnowledgeOwner")

  // Engagement (Step 12)
  kudosGiven    Kudos[]    @relation("KudosFrom")
  kudosReceived Kudos[]    @relation("KudosTo")
  pollVotes     PollVote[]

  // Announcements (Step 14)
  announcements    Announcement[]    @relation("AnnouncementAuthor")
  announcementAcks AnnouncementAck[]

  // Personal development (Step 15)
  duties         Duty[]          @relation("DutyOwner")
  okrs           Okr[]           @relation("OkrOwner")
  checklistItems ChecklistItem[] @relation("ChecklistOwner")

  // Meetings (Step 16)
  meetingsOwned      Meeting[]         @relation("MeetingOwner")
  meetingAttendances MeetingAttendee[]

  // Messages (Stage 1: Groups + DMs)
  conversationsCreated Conversation[]       @relation("ConvCreator")
  conversationMembers  ConversationMember[] @relation("ConvMember")
  messagesSent         Message[]            @relation("MessageAuthor")
  messageReactions     MessageReaction[]
  reminders            Reminder[]
  microsoftAccount     MicrosoftAccount?

  // AssetHub (V1)
  assetRoles          AssetRoleAssignment[] @relation("AssetRoles")
  assetsCustodian      AssetRecord[]         @relation("AssetCustodian")
  assetsCreated        AssetRecord[]         @relation("AssetCreator")
  assetHistoryActions  AssetHistory[]        @relation("AssetHistoryBy")
  assetEventsRequested AssetEvent[]          @relation("AssetEventRequester")
  verificationsRun     VerificationSession[] @relation("VerificationConductor")

  // ── Employee master (imported from the HR sheet; all optional) ──────
  // Canonical fields already above: name(=Full Name), email(=Work Email),
  // designation(=Job Title), tier, departmentId, reportsToId, birthday, joinedOn.
  employeeNumber String? @unique
  firstName      String?
  middleName     String?
  lastName       String?
  displayName    String?
  // job / org
  jobTitle              String?
  secondaryJobTitle     String?
  subDepartment         String?
  location              String?
  country               String?
  reportingManagerEmpNo String?
  dottedLineManager     String?
  // policies (dropdowns → MasterOption values)
  leavePlan                String?
  band                     String?
  payGrade                 String?
  timeType                 String?
  workerType               String?
  shiftPolicy              String?
  weeklyOffPolicy          String?
  attendanceTrackingPolicy String?
  attendanceCaptureScheme  String?
  holidayList              String?
  expensePolicy            String?
  noticePeriod             String?
  attendanceNumber         String?
  // personal (self-service editable)
  dateOfBirth           String?
  gender                String?
  maritalStatus         String?
  marriageDate          String?
  bloodGroup            String?
  physicallyHandicapped String?
  nationality           String?
  mobilePhone           String?
  workPhone             String?
  homePhone             String?
  personalEmail         String? // legacy: superseded by googleEmail/eduportEmail below; kept as the backfill source
  // Where ICKU actually mails this person. `email` above is the account identity
  // (unique, drives the username) and is a mix of domains, so it can't be trusted
  // as a mailbox. eduportEmail is HR-managed and only ~14 staff have one;
  // googleEmail is self-service. Delivery = eduportEmail || googleEmail.
  eduportEmail          String?
  googleEmail           String?
  currentAddrLine1      String?
  currentAddrLine2      String?
  currentAddrCity       String?
  currentAddrState      String?
  currentAddrZip        String?
  currentAddrCountry    String?
  permanentAddrLine1    String?
  permanentAddrLine2    String?
  permanentAddrCity     String?
  permanentAddrState    String?
  permanentAddrZip      String?
  permanentAddrCountry  String?
  fatherName            String?
  motherName            String?
  spouseName            String?
  childrenNames         String?
  panNumber             String?
  aadhaarNumber         String?
  pfNumber              String?
  uanNumber             String?
  // lifecycle (excluded from onboarding — Part 6)
  employmentStatus  String? @default("Working")
  exitDate          String?
  exitStatus        String?
  terminationType   String?
  terminationReason String?
  resignationNote   String?
  costCenter        String?
  profileComments   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([reportsToId])
  @@index([employeeNumber])
}

model AuthCredential {
  id           String @id @default(uuid())
  username     String @unique
  passwordHash String

  // Temp-credential visibility for HR: the initial/reset password is kept in
  // plaintext so HR can see & export it, and is cleared once the employee sets
  // their own password (passwordChanged=true → HR can no longer see it).
  tempPassword    String?
  passwordChanged Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per person per day. `date` is a plain "YYYY-MM-DD" string to avoid
// timezone drift. Weekly-offs, holidays and future days are NOT stored — they are
// derived when the month view is built (see attendance.service.buildMonth).
model AttendanceRecord {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  date     String // "YYYY-MM-DD"
  checkIn  String? // "HH:MM"
  checkOut String?
  hours    Float?
  status   String // present | late | half | absent
  source   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Regularization {
  id           String  @id @default(uuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  date         String // "YYYY-MM-DD" the request is for
  reason       String
  status       String  @default("pending") // pending | approved | rejected
  reviewedById String? // manager who actioned it (plain id, audit field)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Leave (Step 4)
model LeaveType {
  id       String         @id // casual | sick | earned | comp | maternity | lop
  name     String
  total    Float // annual allotment (days)
  color    String
  sort     Int            @default(0)
  requests LeaveRequest[]
}

model LeaveRequest {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  typeId       String
  type         LeaveType @relation(fields: [typeId], references: [id])
  fromDate     String // "YYYY-MM-DD"
  toDate       String
  days         Float
  half         Boolean   @default(false)
  reason       String
  status       String    @default("pending") // pending | approved | rejected | cancelled
  reviewedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([typeId])
}

// Payroll (Step 5) — base compensation per person; payslip breakup is computed live.
model Salary {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  monthlyGross Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One payroll run per calendar month; tracks draft → processed.
model PayrollRun {
  id            String    @id @default(uuid())
  year          Int
  month         Int
  status        String    @default("draft") // draft | processed
  processedById String?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// ── Services (Step 6) ────────────────────────────────────────────

// Expense claim — multi-stage: manager → finance → payment → paid.
model Expense {
  id           String  @id @default(uuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  category     String
  amount       Float
  date         String // "YYYY-MM-DD"
  description  String
  receiptUrl   String? // data URL for now (TODO: move to object storage)
  status       String  @default("manager") // manager | finance | payment | paid | rejected | cancelled
  reviewedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Company asset — assignable to a user, returnable to stock.
model Asset {
  id           String  @id @default(uuid())
  type         String
  tag          String  @unique
  assignedToId String?
  assignedTo   User?   @relation("AssetAssignee", fields: [assignedToId], references: [id])
  assignedDate String?
  returnDate   String?
  condition    String  @default("Good")
  warranty     String  @default("—")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
}

// Helpdesk ticket — raise → assign → resolve → close.
model Ticket {
  id         String  @id @default(uuid())
  userId     String
  user       User    @relation("TicketRaiser", fields: [userId], references: [id])
  category   String
  subject    String
  status     String  @default("open") // open | assigned | resolved | closed
  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])
  raised     String // "YYYY-MM-DD"

  comments TicketComment[]
  // Per-participant read marks — a ticket only ever has two sides (raiser and
  // assignee), so two columns beat a join table here.
  raiserReadAt   DateTime?
  assigneeReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assigneeId])
}

// The conversation on a ticket — raiser ↔ agent.
model TicketComment {
  id       String @id @default(uuid())
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  body     String

  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ── Work: events & tasks (Step 7) ────────────────────────────────

// A recurring company event (result day, exam, batch launch…). Its lifecycle
// state (undated/upcoming/current/overdue/completed) is computed, not stored.
model Event {
  id           String  @id @default(uuid())
  name         String
  description  String  @default("") // optional short description, shown above the SOP
  ownerId      String?
  owner        User?   @relation("EventOwner", fields: [ownerId], references: [id])
  recurrence   String  @default("yearly")
  status       String // confirmed (dated) | tbd | multiple (undated)
  triggerMonth Int? // 1-12 (academic year derives the year)
  triggerDay   Int?
  writeup      String  @default("") // the SOP that persists each year
  approval     String  @default("approved") // pending | approved | rejected
  approverId   String?
  createdById  String?
  // Pending ownership transfer: only the current owner can initiate one, and if
  // the *new* owner's autoApproveProjects is off it waits here for the new owner's
  // manager (ownerApproverId) — the project keeps running under the current owner
  // until approved. Both null when there's no transfer in flight.
  pendingOwnerId  String?
  ownerApproverId String?

  tasks        EventTask[]
  attachments  Attachment[]
  comments     EventComment[]
  conversation Conversation? // Stage 2: the event's chat thread (Messages)
  meetings     Meeting[] // meetings tagged to this event
  activities   EventActivity[] // edit / extension history

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([approverId])
}

// Human-readable audit trail for a project: edits to the project or its tasks,
// and approved deadline extensions — so "who changed what, when" is viewable.
model EventActivity {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actorId   String?
  actorName String   @default("")
  text      String // e.g. "extended 'Book venue' to Jul 27"
  createdAt DateTime @default(now())

  @@index([eventId])
}

model EventTask {
  id            String         @id @default(uuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  dueOffset     Int? // days after the event trigger date
  dueTime       String? // "HH:MM" 24h time-of-day for the due date; null = legacy (midnight)
  completed     Boolean        @default(false)
  completedLate Boolean        @default(false)
  completedAt   DateTime? // when it was marked done — powers month-based delay stats
  sort          Int            @default(0)
  assignees     TaskAssignee[]

  // Deadline-extension request: an assignee proposes a new due date (stored the
  // same way as dueOffset/dueTime); the Project Owner approves → the task's due
  // date becomes these, then the request clears. extReqStatus is 'pending' or null.
  extReqOffset  Int?
  extReqTime    String?
  extReqById    String?
  extReqStatus  String?

  @@index([eventId])
}

// A standalone (ad-hoc) task — assigned to people WITHOUT a project. Its own
// approval flow: gated by the assigner's autoApproveTasks flag; when off it's
// pending the assigner's reporting manager and hidden from assignees until then.
model DirectTask {
  id          String               @id @default(uuid())
  title       String
  assignerId  String
  assigner    User                 @relation("DirectTaskAssigner", fields: [assignerId], references: [id])
  dueDate     String? // "YYYY-MM-DD" (absolute — no project trigger to offset from)
  dueTime     String? // "HH:MM"
  approval    String               @default("approved") // approved | pending | rejected
  approverId  String? // the assigner's manager, while pending
  completed   Boolean              @default(false)
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  assignees   DirectTaskAssignee[]

  @@index([assignerId])
  @@index([approval, approverId])
}

model DirectTaskAssignee {
  taskId         String
  task           DirectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String
  user           User       @relation("DirectTaskAssignee", fields: [userId], references: [id])
  // Pre-approval gate, keyed on the RECIPIENT: 'approved' → they can see & act on
  // it; 'pending' → waiting for this recipient's manager (approverId), hidden from
  // the recipient until then; 'rejected' → that manager declined the assignment.
  approval       String     @default("approved") // approved | pending | rejected
  approverId     String? // the recipient's reporting manager, while pending
  // Post-approval acceptance: the recipient (or their manager) may decline a task
  // they already hold. Distinct from `approval` above (a different lifecycle stage).
  status         String     @default("accepted") // accepted | rejected
  rejectedReason String?

  @@id([taskId, userId])
  @@index([userId])
  @@index([approval, approverId])
}

model TaskAssignee {
  taskId String
  task   EventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User      @relation(fields: [userId], references: [id])

  // Pre-approval gate, keyed on the RECIPIENT (same rule as DirectTaskAssignee):
  // 'approved' → live for them; 'pending' → waiting for the recipient's manager
  // (approverId), hidden from the recipient; 'rejected' → the manager declined it.
  approval   String  @default("approved") // approved | pending | rejected
  approverId String? // the recipient's reporting manager, while pending

  // Per-assignee acceptance. Newly assigned tasks are 'accepted' by default; the
  // assignee (or their manager) may 'rejected' it — the task stays for others.
  status         String    @default("accepted")
  rejectedReason String?
  rejectedAt     DateTime?

  @@id([taskId, userId])
  @@index([userId])
  @@index([approval, approverId])
}

model Attachment {
  id      String  @id @default(uuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind    String // pdf | link
  label   String
  url     String?
}

model EventComment {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  parentId  String? // for threaded replies
  body      String
  createdAt DateTime @default(now())

  @@index([eventId])
}

// ── HR lifecycle: onboarding & exit (Step 8) ─────────────────────

// A pre-hire joiner tracked through a fixed joining checklist. `done` holds the
// completed checklist item labels.
model Onboarding {
  id           String      @id @default(uuid())
  name         String
  designation  String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  joinDate     String // "YYYY-MM-DD"
  offer        String      @default("Sent") // Sent | Accepted
  done         String[]    @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A resignation with a clearance workflow. Full-&-final is computed on demand
// from payroll + leave.
model Exit {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  submitted     String // "YYYY-MM-DD"
  lastDay       String
  reason        String
  exitInterview Boolean  @default(false)
  clearance     String[] @default([]) // completed clearance steps
  status        String   @default("notice") // notice | withdrawn

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Admin Console (Step 9) ───────────────────────────────────────

// The editable RBAC matrix (tier → capability). Presence of a row = granted.
model TierCapability {
  tier       String
  capability String

  @@id([tier, capability])
}

// System settings toggles: approval workflows, integrations, feature flags.
model Setting {
  id          String  @id @default(uuid())
  category    String // workflow | integration | flag
  key         String  @unique
  label       String
  description String  @default("")
  chain       String? // for workflow rows
  enabled     Boolean @default(false)
  sort        Int     @default(0)
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ── Meetings (Step 16) ───────────────────────────────────────────
model Meeting {
  id        String            @id @default(uuid())
  title     String
  date      String // "YYYY-MM-DD"
  time      String // "HH:MM"
  ownerId   String
  owner     User              @relation("MeetingOwner", fields: [ownerId], references: [id])
  recurring String            @default("One-off") // Daily | Weekly | Monthly | One-off
  recurEnd   String           @default("never") // never | until | count (for recurring)
  recurUntil String?          // "YYYY-MM-DD" when recurEnd=until
  recurCount Int?             // number of occurrences when recurEnd=count
  durationMin Int             @default(60) // meeting length in minutes
  mode      String            @default("offline") // offline | online | hybrid
  meetingLink String?         // Zoom/Teams/Meet link (for online/hybrid)
  msEventId String?           // Graph event id when we created a real Teams meeting
  inviteSeq Int    @default(0) // .ics SEQUENCE; bumped each edit so calendars accept the update

  // Physical room (offline/hybrid only)
  room      String? // Prana | Collab | Synergy | Others
  roomOther String? // free text when room = Others

  // Optional link to an institutional event (one per meeting)
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  agenda    String[]          @default([])
  minutes   String            @default("")
  minutesFileUrl  String? // optional minutes PDF
  minutesFileName String?
  attendees MeetingAttendee[]
  actions   MeetingAction[]
  createdAt DateTime          @default(now())

  @@index([date])
}

model MeetingAttendee {
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@id([meetingId, userId])
  @@index([userId])
}

model MeetingAction {
  id        String  @id @default(uuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text      String
  ownerId   String?
  done      Boolean @default(false)
  sort      Int     @default(0)
}

// ── Personal development: duties, OKRs, checklists (Step 15) ──────
// A responsibility set by the person's manager (read-only to the person).
model Duty {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("DutyOwner", fields: [userId], references: [id])
  text        String
  createdById String?
  sort        Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
}

// An objective for a user in a given month. percent = % achieved.
model Okr {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("OkrOwner", fields: [userId], references: [id])
  year        Int
  month       Int
  objective   String
  target      String
  percent     Int?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([userId, year, month])
}

// Per user-month approval state for OKRs (set by the manager).
model OkrApproval {
  userId   String
  year     Int
  month    Int
  approved Boolean @default(false)

  @@id([userId, year, month])
}

// A recurring checklist item. `checkedAt` timestamps the last tick; whether it
// counts as "done" is derived from the current period (daily/weekly/…).
model ChecklistItem {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation("ChecklistOwner", fields: [userId], references: [id])
  frequency   String // Daily | Weekly | Monthly | Yearly
  text        String
  checkedAt   DateTime?
  createdById String?
  sort        Int       @default(0)
  createdAt   DateTime  @default(now())
  completions ChecklistCompletion[]

  @@index([userId])
}

// A manager-set deadline for an employee's checklist items of one frequency.
// When none is set, sensible defaults apply (Daily 6pm / Weekly Fri 6pm /
// Monthly last-day 6pm), so pending/delay tracking works before customisation.
model ChecklistDeadline {
  id         String @id @default(uuid())
  userId     String
  frequency  String // Daily | Weekly | Monthly
  time       String @default("18:00") // "HH:MM"
  weekday    Int? // 0=Sun … 6=Sat, for Weekly
  dayOfMonth Int? // 1–31 (clamped to the month's length), for Monthly

  @@unique([userId, frequency])
  @@index([userId])
}

// One row per checklist item per period once completed — the history behind
// delayed-completion reporting. `late` = completed after that period's deadline
// (a "black mark"). `clearedById` is set when a manager Cleared the item for the
// user instead of the user checking it: with late=false it's an excused clear
// (neutral, not a black mark), with late=true it's a cleared-as-black-mark.
model ChecklistCompletion {
  id          String        @id @default(uuid())
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String
  periodKey   String // "2026-07-19" | "2026-W7-14" | "2026-7" | "2026"
  completedAt DateTime      @default(now())
  dueAt       DateTime?
  late        Boolean       @default(false)
  clearedById String? // manager who Cleared it (null = the user checked it)

  @@unique([itemId, periodKey])
  @@index([userId, late])
}

// Rolling activity log for checklists — powers the 7-day history view and the
// restore-a-deleted-item action. `text`/`frequency` snapshot the item so a
// deleted one can be recreated. Rows older than 7 days are pruned on write.
model ChecklistActivity {
  id        String   @id @default(uuid())
  userId    String // whose checklist (the owner)
  itemId    String? // the live item, when it still exists
  actorId   String? // who performed the action
  action    String // added | edited | deleted | checked | unchecked | cleared | restored
  text      String // snapshot of the item text at the time
  frequency String? // snapshot, so a deleted item can be restored
  late      Boolean  @default(false) // for checked/cleared: counted as a black mark
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Announcements (Step 14) ──────────────────────────────────────
model Announcement {
  id        String            @id @default(uuid())
  scope     String // Organization | Academics | Growth | Technology | Operations
  title     String
  authorId  String
  author    User              @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  body      String
  acks      AnnouncementAck[]
  createdAt DateTime          @default(now())

  @@index([createdAt])
}

model AnnouncementAck {
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())

  @@id([announcementId, userId])
}

// ── Engagement (Step 12) ─────────────────────────────────────────
model Kudos {
  id        String   @id @default(uuid())
  fromId    String
  from      User     @relation("KudosFrom", fields: [fromId], references: [id])
  toId      String
  to        User     @relation("KudosTo", fields: [toId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Poll {
  id        String       @id @default(uuid())
  question  String
  active    Boolean      @default(true)
  options   PollOption[]
  votes     PollVote[]
  createdAt DateTime     @default(now())
}

model PollOption {
  id     String     @id @default(uuid())
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label  String
  sort   Int        @default(0)
  votes  PollVote[]
}

model PollVote {
  id       String     @id @default(uuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
}

// ── Knowledge / SOP library (Step 11) ────────────────────────────
model KnowledgeDoc {
  id           String      @id @default(uuid())
  title        String
  type         String // SOP | Policy | Guide | FAQ | Manual
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  ownerId      String?
  owner        User?       @relation("KnowledgeOwner", fields: [ownerId], references: [id])
  body         String      @default("")
  link         String? // optional external doc URL
  eventId      String? // optional link to an event
  tags         String[]    @default([])
  attachments  Json? // [{ kind, label, url }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([departmentId])
}

// ─── Messages (Stage 1: Groups + Direct Messages) ────────────────────
// A Conversation is either a named group ("group") or a 1:1 direct thread
// ("dm"). Membership is explicit so a group is only visible to its members.
model Conversation {
  id          String               @id @default(uuid())
  type        String // "group" | "dm" | "event"
  name        String? // group/event name; null for DMs (name derived from the other member)
  description String? // optional group/channel description, shown in the details drawer
  createdById String
  createdBy   User                 @relation("ConvCreator", fields: [createdById], references: [id])
  eventId     String?              @unique // set for type "event" — links to the Event
  event       Event?               @relation(fields: [eventId], references: [id])
  members     ConversationMember[]
  messages    Message[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([type])
}

model ConversationMember {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConvMember", fields: [userId], references: [id])
  role           String       @default("member") // "owner" | "member"
  lastReadAt     DateTime? // for unread badges
  mutedAt        DateTime? // set when this member mutes the conversation (no unread badge)
  section        String? // this member's personal sidebar section/group for the channel
  joinedAt       DateTime     @default(now())

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation("MessageAuthor", fields: [authorId], references: [id])
  body           String       @default("")
  parentId       String? // thread parent (null = top-level message)
  parent         Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Message[]    @relation("MessageThread")
  attachments    Json? // [{ kind: "image" | "file", name, url }]
  mentions       String[]     @default([]) // userIds mentioned via @
  reactions      MessageReaction[]
  reminders      Reminder[]
  editedAt       DateTime? // set when the author edits
  deletedAt      DateTime? // soft-delete tombstone (keeps thread structure)
  pinnedAt       DateTime? // set when a member pins this message to the conversation
  pinnedById     String? // who pinned it (userId; resolved to a name client-side)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([parentId])
}

// Emoji reactions on a message (Slack-style). One row per user+emoji.
model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// "Remind me" — a personal reminder, optionally anchored to a message.
model Reminder {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  messageId      String? // the message it was set on (null after the message is deleted)
  message        Message?  @relation(fields: [messageId], references: [id], onDelete: SetNull)
  conversationId String? // for deep-linking back to the conversation
  text           String // snapshot of what to be reminded about
  remindAt       DateTime
  doneAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, doneAt])
}

// ─── Master data (Part 7/8) ──────────────────────────────────────────
// Configurable dropdown values, one row per option. `type` is the property
// (e.g. "jobTitle", "shiftPolicy"); `value` is the label shown in dropdowns.
// `meta` holds an optional definition (e.g. a weekly-off rule) for policies.
model MasterOption {
  id        String   @id @default(uuid())
  type      String
  value     String
  active    Boolean  @default(true)
  meta      Json?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, value])
  @@index([type])
}

// ─── AssetHub (V1) — Fixed Asset Register ────────────────────────────
// Masters are retired (active=false), never deleted, per the PRD.

model AssetCategory {
  id              String             @id @default(uuid())
  code            String             @unique // e.g. FUR — used in Asset IDs
  name            String // Furniture & Fixtures
  defaultGlCodeId String?
  defaultGlCode   GlCode?            @relation(fields: [defaultGlCodeId], references: [id])
  active          Boolean            @default(true)
  subCategories   AssetSubCategory[]
  records         AssetRecord[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model AssetSubCategory {
  id                 String        @id @default(uuid())
  code               String // e.g. BED — used in Asset IDs
  name               String // Steel Cot
  categoryId         String
  category           AssetCategory @relation(fields: [categoryId], references: [id])
  defaultGstRate     Float         @default(18) // percent
  defaultItcEligible Boolean       @default(true)
  itcBlockReason     String? // shown only when ITC = No
  active             Boolean       @default(true)
  records            AssetRecord[]
  verifyCounts       VerificationCount[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([categoryId, code])
}

model AssetSite {
  id        String          @id @default(uuid())
  code      String          @unique // SC
  name      String // Single Campus
  active    Boolean         @default(true)
  buildings AssetBuilding[]
  records   AssetRecord[]
  createdAt DateTime        @default(now())
}

model AssetBuilding {
  id        String      @id @default(uuid())
  code      String // HSLA
  name      String // Hostel A
  siteId    String
  site      AssetSite   @relation(fields: [siteId], references: [id])
  active    Boolean     @default(true)
  rooms     AssetRoom[]
  records   AssetRecord[]
  createdAt DateTime    @default(now())

  @@unique([siteId, code])
}

model AssetRoom {
  id         String        @id @default(uuid())
  number     String // "101" — no type/AC/sharing tracked (PRD)
  buildingId String
  building   AssetBuilding @relation(fields: [buildingId], references: [id])
  active     Boolean       @default(true)
  records    AssetRecord[]

  @@unique([buildingId, number])
}

model AssetVendor {
  id        String   @id @default(uuid())
  code      String   @unique // auto: VEN-0001
  name      String
  gstin     String?
  pan       String?
  contact   String?
  active    Boolean  @default(true)
  records   AssetRecord[]
  createdAt DateTime @default(now())
}

model GlCode {
  id         String          @id @default(uuid())
  code       String          @unique // GL-1200
  name       String // Furniture & Fixtures
  active     Boolean         @default(true)
  categories AssetCategory[]
  records    AssetRecord[]
  createdAt  DateTime        @default(now())
}

// Value bands deciding the approval sequence (thresholds admin-editable).
model AssetApprovalBand {
  id        String   @id @default(uuid())
  minValue  Float    @default(0)
  maxValue  Float? // null = no upper cap
  approvers String[] // role keys in sequence, e.g. ["BRANCH_MANAGER","FINANCE_EXECUTIVE"]
  label     String?
  sort      Int      @default(0)
}

// Who plays which AssetHub role, optionally scoped to a site/building.
// Roles: OPERATIONS | BRANCH_MANAGER | FINANCE_EXECUTIVE | FINANCE_MANAGER | CFO | ASSET_ADMIN
model AssetRoleAssignment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("AssetRoles", fields: [userId], references: [id])
  role       String
  siteId     String? // null = all sites
  buildingId String? // null = all buildings
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([role])
}

// One row per physical asset. Bulk create makes N of these. Status runs the
// PRD workflow; approvalChain is the band-derived approver sequence snapshot.
model AssetRecord {
  id       String @id @default(uuid())
  assetTag String @unique // e.g. SC-HSLA-BED-0001

  categoryId    String
  category      AssetCategory    @relation(fields: [categoryId], references: [id])
  subCategoryId String
  subCategory   AssetSubCategory @relation(fields: [subCategoryId], references: [id])
  description   String
  make          String?
  model         String?
  serialNumber  String?
  quantity      Int              @default(1)

  siteId     String
  site       AssetSite     @relation(fields: [siteId], references: [id])
  buildingId String
  building   AssetBuilding @relation(fields: [buildingId], references: [id])
  roomId     String?
  room       AssetRoom?    @relation(fields: [roomId], references: [id])

  custodianId String
  custodian   User   @relation("AssetCustodian", fields: [custodianId], references: [id])

  dateOfPurchase String? // "YYYY-MM-DD"
  vendorId       String?
  vendor         AssetVendor? @relation(fields: [vendorId], references: [id])
  invoiceNumber  String?
  taxableValue   Float?
  gstAmount      Float?
  totalValue     Float? // auto: taxable + GST

  photoUrl   String?
  invoiceUrl String?

  warrantyMonths    Int?
  insured           Boolean @default(false)
  insurancePolicyNo String?
  insuranceExpiry   String? // "YYYY-MM-DD"

  // Finance-stage fields
  glCodeId             String?
  glCode               GlCode? @relation(fields: [glCodeId], references: [id])
  itcEligible          Boolean?
  itcBlockReason       String?
  datePutToUse         String? // "YYYY-MM-DD"
  capitalisationMethod String? // Invoice | Vendor Confirmation | Deemed Cost | Nominal
  deemedCostBasis      String?
  legacy               Boolean @default(false)

  // Workflow
  status         String    @default("draft") // draft|pending_branch|pending_finance_review|pending_finance_approval|pending_ack|active|under_repair|in_transfer|disposed|written_off|void
  approvalChain  String[]  @default([]) // role keys, snapshot from the matching band at submit
  chainIndex     Int       @default(0) // next approver position in approvalChain
  submittedAt    DateTime?
  ackRequestedAt DateTime? // for the 48h escalation
  acknowledgedAt DateTime?
  remarks        String?
  bulkBatchId    String? // groups records made in one bulk lot (Phase 3)

  createdById String
  createdBy   User               @relation("AssetCreator", fields: [createdById], references: [id])
  history     AssetHistory[]
  events      AssetEvent[]
  verifyLines VerificationLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([siteId, buildingId])
  @@index([custodianId])
  @@index([bulkBatchId])
}

// Lifecycle requests on an active asset (PRD §9): transfer / capex / damage /
// disposal / write-off. Each carries its own fixed approval chain by type.
model AssetEvent {
  id            String      @id @default(uuid())
  assetId       String
  asset         AssetRecord @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type          String // transfer|capex|damage|disposal|write_off
  status        String      @default("pending") // pending|approved|rejected
  reason        String
  amount        Float? // capex addition / disposal proceeds / write-off value
  toSiteId      String? // transfer destination (plain ids; names resolved in service)
  toBuildingId  String?
  toRoomId      String?
  toCustodianId String?
  docUrl        String?
  approvalChain String[]    @default([]) // role keys for this event type
  chainIndex    Int         @default(0)
  requestedById String
  requestedBy   User        @relation("AssetEventRequester", fields: [requestedById], references: [id])
  createdAt     DateTime    @default(now())
  decidedAt     DateTime?

  @@index([assetId])
  @@index([status])
}

// Physical verification (PRD §10): an audit of a location against the register.
// item mode → one line per expected asset; count mode → expected vs actual per sub-category.
model VerificationSession {
  id            String    @id @default(uuid())
  title         String
  mode          String // item | count
  siteId        String
  buildingId    String
  roomId        String?
  categoryId    String?
  status        String    @default("open") // open | closed
  expectedCount Int       @default(0) // snapshot of register count at creation
  conductedById String
  conductedBy   User      @relation("VerificationConductor", fields: [conductedById], references: [id])
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  lines  VerificationLine[]
  counts VerificationCount[]

  @@index([status])
}

model VerificationLine {
  id        String              @id @default(uuid())
  sessionId String
  session   VerificationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assetId   String
  asset     AssetRecord         @relation(fields: [assetId], references: [id])
  result    String              @default("pending") // pending | found | missing | damaged | wrong_location
  note      String?
  resolved  Boolean             @default(false) // a follow-up event (write-off/damage) was raised

  @@index([sessionId])
}

model VerificationCount {
  id            String              @id @default(uuid())
  sessionId     String
  session       VerificationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subCategoryId String
  subCategory   AssetSubCategory    @relation(fields: [subCategoryId], references: [id])
  expected      Int                 @default(0)
  actual        Int?

  @@index([sessionId])
}

// The asset's history timeline + audit entries (who did what, why).
model AssetHistory {
  id      String      @id @default(uuid())
  assetId String
  asset   AssetRecord @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action  String // created|submitted|approved|sent_back|finance_edited|acknowledged|voided|...
  byId    String?
  by      User?       @relation("AssetHistoryBy", fields: [byId], references: [id])
  note    String?
  meta    Json? // e.g. field changes { field: [old, new] }
  createdAt DateTime  @default(now())

  @@index([assetId])
}

// A user's connected Microsoft 365 (Outlook/Teams) account. Tokens are stored
// encrypted (see lib/secretbox.js). One per user; connecting is self-service.
model MicrosoftAccount {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  msId         String // Graph user id
  email        String
  displayName  String   @default("")
  accessToken  String // encrypted
  refreshToken String // encrypted
  expiresAt    DateTime // access-token expiry
  scope        String   @default("")
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}
