# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────
# LOCAL DEV — your own Postgres:
DATABASE_URL="postgresql://icku:icku@localhost:5432/icku?schema=public"
#
# PRODUCTION with SUPABASE — in the Supabase dashboard: Project Settings →
# Database → "Connection string" → choose the "Session pooler" (port 5432).
# Copy it and put your database password in place of [YOUR-PASSWORD]. It looks like:
#   DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── JWT (used in Step 2 — Auth) ─────────────────────────
# Generate strong secrets, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
